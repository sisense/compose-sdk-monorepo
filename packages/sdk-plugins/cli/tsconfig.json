{
  "extends": "../../../tsconfig.json",
  "compilerOptions": {
    "moduleResolution": "node",
    "rootDir": "./src",
    "outDir": "./dist",
    "module": "ES2020",
    "target": "ES2020",
    "lib": ["ES2020"],
    "types": ["node"],
    "sourceMap": false,
    "declarationMap": false,
    "declaration": true,
    "composite": false
  },
  "include": ["./src/**/*"],
  "exclude": ["./src/**/*.test.ts"]
}
