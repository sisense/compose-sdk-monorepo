{
  "name": "@sisense/sdk-plugins-dev",
  "homepage": "https://developer.sisense.com/guides/sdk/",
  "description": "Compose SDK plugin development experience — DevApp, Vite plugin for Fusion, and deploy script",
  "repository": {
    "type": "git",
    "url": "https://github.com/sisense/compose-sdk-monorepo",
    "directory": "packages/sdk-plugins/dev"
  },
  "keywords": [
    "Sisense",
    "Compose SDK"
  ],
  "version": "2.25.0",
  "type": "module",
  "exports": {
    ".": "./dist/index.js",
    "./vite-plugin-fusion": "./dist/vite-plugin/vite-plugin-fusion.js",
    "./scripts/deploy": "./dist/scripts/deploy.js"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "vite-plugin-fusion": [
        "./dist/vite-plugin/vite-plugin-fusion.d.ts"
      ],
      "scripts/deploy": [
        "./dist/scripts/deploy.d.ts"
      ]
    }
  },
  "license": "SEE LICENSE IN LICENSE.md",
  "author": "Sisense",
  "scripts": {
    "build": "run build:scripts && run build:vite-plugin && vite build",
    "build:prod": "run build:scripts && run build:vite-plugin && vite build --mode production",
    "build:vite-plugin": "rm -f dist/vite-plugin-fusion.js dist/vite-plugin-fusion.d.ts && tsc --project tsconfig.plugin.json",
    "build:scripts": "tsc --project tsconfig.scripts.json",
    "clean": "rm -rf dist coverage tsconfig.tsbuildinfo",
    "format": "run -T prettier --write .",
    "format:check": "run -T prettier --check .",
    "lint": "run -T eslint . --quiet",
    "lint:fix": "run lint --fix",
    "vitest": "run -T vitest",
    "test": "run vitest run",
    "test:watch": "run vitest watch",
    "test:coverage": "run vitest run --coverage --passWithNoTests"
  },
  "dependencies": {
    "vite-plugin-css-injected-by-js": "^3.5.2",
    "vite-plugin-dts": "^3.9.1",
    "vite-plugin-zip-pack": "^1.2.4"
  },
  "devDependencies": {
    "@sisense/sdk-ui": "workspace:^",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.0.0",
    "@types/react": "18.3.0",
    "@vitest/coverage-istanbul": "3.2.4",
    "jsdom": "^22.1.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "typescript": "4.8.4",
    "vite": "^5",
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "@sisense/sdk-ui": "workspace:^",
    "react": "^17.0.0 || ^18.0.0 || ^19.0.0",
    "react-dom": "^17.0.0 || ^18.0.0 || ^19.0.0",
    "vite": "^5"
  },
  "packageManager": "yarn@3.2.3",
  "volta": {
    "extends": "../../../package.json"
  }
}
