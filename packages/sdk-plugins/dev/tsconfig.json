{
  "extends": "../../../tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "rootDir": "./src",
    "outDir": "./dist",
    "suppressImplicitAnyIndexErrors": false,
    "module": "ESNext",
    "moduleResolution": "node",
    "baseUrl": ".",
    "paths": {
      "@sisense/sdk-ui": ["../../sdk-ui/dist/packages/sdk-ui/src/index.d.ts"]
    }
  },
  "include": ["./src/**/*"],
  "exclude": ["./scripts/**/*"],
  "references": [{ "path": "../../sdk-ui" }]
}
