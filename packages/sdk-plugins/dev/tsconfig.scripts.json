{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "moduleResolution": "node",
    "rootDir": "./scripts",
    "outDir": "./dist/scripts",
    "module": "ES2022",
    "target": "ES2022",
    "lib": ["ES2022"],
    "types": ["node"],
    "sourceMap": false,
    "declarationMap": false,
    "declaration": false,
    "composite": false
  },
  "include": ["./scripts/**/*.ts"],
  "exclude": ["./scripts/**/*.test.ts"]
}
