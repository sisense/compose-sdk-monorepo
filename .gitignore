# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
node_modules
/.pnp
.pnp.js

# testing
coverage/
/.nyc_output

# production
/build
/lib
dist/

# misc
.DS_Store
.env.local
.env.development.local
.env.test.local
.env.production.local
.run/*

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# TypeScript incremental compilation cache
*.tsbuildinfo

# Yarn: not using Zero Install
# https://yarnpkg.com/getting-started/qa#which-files-should-be-gitignored
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# Yarn: using Zero Install
#.yarn/unplugged
#.yarn/build-state.yml
.idea
.vscode

# generated docs from typedoc
docs/
docs-internal/
e2e/results.xml

# generated from storybook build
storybook-static/
packages/sdk-*/vite.config.ts.timestamp-*

# generated from nx build
.nx/cache
.nx/workspace-data
.swc

# generated from eslint
.eslintcache

# cursor ignore
.cursorignore

.cursor/rules/__personal__/*



# complex snapshot testing for Charts refactoring
*.snapshot.json
*.snapshot.test.ts
*.snapshot.test.ts.snap
dist-zip/

# ignore the generated plugins repository
packages/sdk-plugins/sdk-plugins-repo-test/
examples/plugins-demo/demo-plugin/node_modules/
examples/plugins-demo/demo-plugin/src/
examples/plugins-demo/demo-plugin/dev/
examples/plugins-demo/demo-plugin/tsconfig.json
examples/plugins-demo/demo-plugin/vite.config.ts
examples/plugins-demo/demo-plugin/README.md
examples/plugins-demo/demo-plugin/.editorconfig
examples/plugins-demo/demo-plugin/.env.local.example
examples/plugins-demo/demo-plugin/.eslintrc.cjs
examples/plugins-demo/demo-plugin/.gitattributes
examples/plugins-demo/demo-plugin/.gitignore
examples/plugins-demo/demo-plugin/.npmignore
examples/plugins-demo/demo-plugin/.prettierignore
examples/plugins-demo/demo-plugin/.prettierrc
examples/plugins-demo/angular/.angular
